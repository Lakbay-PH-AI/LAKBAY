# Hostinger / Node hosting
NODE_ENV=production
PORT=3000
PUBLIC_APP_URL=https://your-domain.example

# Database
# Use this for a managed Postgres database. The bundled server keeps secrets on the backend.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lakbay_ai

# Auth/session
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_HOURS=168

# Optional AI provider keys. Never expose these to the frontend.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=

# Webhooks
WEBHOOK_SIGNING_SECRET=
